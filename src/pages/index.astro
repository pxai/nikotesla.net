---
// Server-side frontmatter - static landing page for Niko Tesla
import '../styles/global.css';
import '../styles/index.css';
import logo from '../images/logo.svg';
import favicon from '../images/favicon.png';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={favicon.src} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Niko Tesla</title>
		<meta name="description" content="Niko Tesla - Alternate Current, Magnetic Fields, and the Future of Energy." />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;400;700&display=swap" rel="stylesheet">
		<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-6TEETEBKZR"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-6TEETEBKZR');
</script>
	</head>
	<body>
		<div class="grid-overlay" id="grid"></div>
		<div class="glow-container">
			<div class="glow-orb" id="orb1"></div>
			<div class="glow-orb-secondary" id="orb2"></div>
		</div>
		<main class="content">
			<h1 id="title">Niko Tesla</h1>
			<h3>y el</h3>
			<h3>Ingenio de Silicio</h3>	
    <img src={logo.src} alt="Logo" class="logo" />

			<h4>P.X. ALTADILL</h4>

			<div class="nav-container">
				<a href="/ejemplares" class="btn-ejemplares" id="btn-ejemplares">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
					Ver Ejemplares
				</a>
				<a href="/making-off" class="btn-ejemplares" id="btn-makingoff">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="btn-icon"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6 6h10M6 10h10M6 14h10"/></svg>
					Encuadernación
				</a>
			</div>

			<footer class="site-footer">
				<a href="https://x.com/nikoteslabook" class="social-link" target="_blank" rel="noopener noreferrer">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="btn-icon"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.912-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
					@nikoteslabook
				</a>
				<a href="https://www.tiktok.com/@nikotesla.net" class="social-link" target="_blank" rel="noopener noreferrer">
