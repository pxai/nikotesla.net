---
import '../styles/global.css';
import '../styles/ejemplares.css';
import logo from '../images/logo.svg';
import favicon from '../images/favicon.png';

const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={favicon.src} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Ejemplares - Niko Tesla</title>
		<meta name="description" content="Ejemplares de Niko Tesla y el Ingenio de Silicio" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;400;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="grid-overlay" id="grid"></div>
		<div class="glow-container">
			<div class="glow-orb" id="orb1"></div>
			<div class="glow-orb-secondary" id="orb2"></div>
		</div>

		<main class="container">
			<header class="header">
				<a href="/" class="btn-back">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
					Volver
				</a>
				<div class="logo-wrapper">
					<img src={logo.src} alt="Logo" class="logo" />
				</div>
			</header>

			<section class="content-section">
				<div class="text-group">
					<h1 class="page-title">
						<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="title-icon"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
						Ejemplares
					</h1>
					<p class="subtitle">Ejemplares de Niko Tesla y el Ingenio de Silicio</p>
				</div>

				<div class="map-layout">
					<div class="sidebar">
						<h3 class="sidebar-title">Ciudades</h3>
						<div class="locations-list" id="locations-list">
							<!-- Items generated from the locations array in JS -->
						</div>
					</div>

					<div class="map-container">
						<div id="map"></div>
					</div>
				</div>
			</section>
		</main>

		<!-- Google Maps Integration script -->
		<script define:vars={{ googleMapsApiKey }}>
			const locations = [
				{
					id: "bilbao",
					name: "Bilbao",
					lat: 43.2712379,
					lng: -2.9422817,
					info: "Universidad de Deusto"
				},
				{
					id: "usurbil",
					name: "Usurbil",
					lat: 43.2361972,
					lng: -2.0660026,
					info: "Usurbil"
				},
				{
					id: "logrono",
					name: "Logroño",
					lat: 42.4635088,
					lng: -2.425896,
					info: "Departamento de Matemáticas y Computación"
				},
				{
					id: "pamplona",
					name: "Pamplona",
					lat: 42.8175308,
					lng: -1.6693907,
					info: "Barrio de San Juan"
				},
				{
					id: "sarriguren",
					name: "Sarriguren",
					lat: 42.8127472,
					lng: -1.5978708,
					info: "Sarriguren"
				}
			];

			// Render sidebar items dynamically from the locations array
			const listContainer = document.getElementById("locations-list");
			if (listContainer) {
				listContainer.innerHTML = locations.map((loc) => {
					return `
						<div class="sidebar-item" data-id="${loc.id}">
							<div class="dot"></div>
							<span class="location-name">${loc.name}</span>
						</div>
					`;
				}).join('');
			}

			// Dark palette tailored Google Maps styles to match page design system
			const mapStyle = [
				{ "elementType": "geometry", "stylers": [{ "color": "#0b2545" }] },
				{ "elementType": "labels.text.stroke", "stylers": [{ "color": "#0b2545" }] },
				{ "elementType": "labels.text.fill", "stylers": [{ "color": "#38bdf8" }] },
				{
					"featureType": "administrative",
					"elementType": "geometry.stroke",
					"stylers": [{ "color": "#1e3a8a" }]
				},
				{
					"featureType": "administrative.land_parcel",
					"elementType": "labels.text.fill",
					"stylers": [{ "color": "#38bdf8" }]
				},
				{
					"featureType": "landscape.man_made",
					"elementType": "geometry.stroke",
					"stylers": [{ "color": "#1e3a8a" }]
				},
				{
					"featureType": "landscape.natural",
					"elementType": "geometry",
					"stylers": [{ "color": "#081b33" }]
				},
				{
					"featureType": "poi",
					"elementType": "geometry",
					"stylers": [{ "color": "#0b2545" }]
				},
				{
					"featureType": "poi",
					"elementType": "labels.text.fill",
					"stylers": [{ "color": "#38bdf8" }]
				},
				{
					"featureType": "poi.park",
					"elementType": "geometry.fill",
					"stylers": [{ "color": "#071e3d" }]
				},
				{
					"featureType": "road",
					"elementType": "geometry",
					"stylers": [{ "color": "#08203e" }]
				},
				{
					"featureType": "road",
					"elementType": "geometry.stroke",
					"stylers": [{ "color": "#1e3a8a" }]
				},
				{
					"featureType": "road",
					"elementType": "labels.text.fill",
					"stylers": [{ "color": "#38bdf8" }]
				},
				{
					"featureType": "road.highway",
					"elementType": "geometry",
					"stylers": [{ "color": "#15315b" }]
				},
				{
					"featureType": "road.highway",
					"elementType": "geometry.stroke",
					"stylers": [{ "color": "#1e3a8a" }]
				},
				{
					"featureType": "water",
					"elementType": "geometry",
					"stylers": [{ "color": "#05162e" }]
				},
				{
					"featureType": "water",
					"elementType": "labels.text.fill",
					"stylers": [{ "color": "#38bdf8" }]
				}
			];

			window.initMap = function() {
				const mapContainer = document.getElementById("map");
				if (!mapContainer) return;

				const bounds = new google.maps.LatLngBounds();

				const map = new google.maps.Map(mapContainer, {
					zoom: 8,
					styles: mapStyle,
					disableDefaultUI: false,
					zoomControl: true,
					mapTypeControl: false,
					scaleControl: true,
					streetViewControl: false,
					rotateControl: false,
					fullscreenControl: true
				});

				const markers = {};
				const infoWindow = new google.maps.InfoWindow();

				locations.forEach((loc) => {
					const pos = { lat: loc.lat, lng: loc.lng };

					const marker = new google.maps.Marker({
						position: pos,
						map: map,
						title: loc.name,
					});

					markers[loc.id] = marker;
					bounds.extend(pos);

					const openInfoWindow = () => {
						infoWindow.setContent(`
							<div class="map-info-window">
								<h4 class="map-info-title">${loc.name}</h4>
								<p class="map-info-text">${loc.info}</p>
							</div>
						`);
						infoWindow.open(map, marker);

						// Highlight corresponding sidebar item
						const sidebarItems = document.querySelectorAll(".sidebar-item");
						sidebarItems.forEach(el => {
							if (el.getAttribute("data-id") === loc.id) {
								el.classList.add("active");
								el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
							} else {
								el.classList.remove("active");
							}
						});
					};

					marker.addListener("click", openInfoWindow);
				});

				// Auto fit elements
				map.fitBounds(bounds);

				// Connect sidebar actions
				const sidebarItems = document.querySelectorAll(".sidebar-item");
				sidebarItems.forEach((item) => {
					item.addEventListener("click", () => {
						sidebarItems.forEach(el => el.classList.remove("active"));
						item.classList.add("active");

						const locId = item.getAttribute("data-id");
						const loc = locations.find(l => l.id === locId);
						if (loc) {
							const marker = markers[locId];
							map.setZoom(11);
							map.panTo({ lat: loc.lat, lng: loc.lng });

							infoWindow.setContent(`
								<div class="map-info-window">
									<h4 class="map-info-title">${loc.name}</h4>
									<p class="map-info-text">${loc.info}</p>
								</div>
							`);
							infoWindow.open(map, marker);
						}
					});
				});

				// Recenter map on window resize
				window.addEventListener("resize", () => {
					map.fitBounds(bounds);
				});
			};

			// Load the script element asynchronously
			const script = document.createElement("script");
			script.src = `https://maps.googleapis.com/maps/api/js?key=${googleMapsApiKey}&callback=initMap`;
			script.async = true;
			script.defer = true;
			document.head.appendChild(script);
		</script>
	</body>
</html>
