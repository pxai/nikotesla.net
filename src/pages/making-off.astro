---
import '../styles/global.css';
import '../styles/makingoff.css';
import logo from '../images/logo.svg';
import favicon from '../images/favicon.png';

// Import bookbinding process images
import img1 from '../images/makingoff/1.jpg';
import img2 from '../images/makingoff/2.jpg';
import img3 from '../images/makingoff/3.jpg';
import img4 from '../images/makingoff/4.jpg';
import img5 from '../images/makingoff/5.jpg';

const steps = [
	{
		number: "01",
		title: "Costura de cuadernillos",
		description: "Inicio de la costura artesanal de las firmas o cuadernillos utilizando una aguja curva de encuadernación, hilo resistente y cintas de soporte.",
		image: img1
	},
	{
		number: "02",
		title: "Costura detallada sobre cintas",
		description: "Detalle de los puntos de costura envolviendo las cintas de soporte blancas, lo que proporciona una estructura flexible y duradera al lomo.",
		image: img2
	},
	{
		number: "03",
		title: "Alineado y encolado inicial",
		description: "Alineación del bloque del libro y prensado del lomo en prensa de madera, con las hojas de guarda negras preparadas y listas para su colocación.",
		image: img3
	},
	{
		number: "04",
		title: "Refuerzo del lomo y cabezadas",
		description: "Aplicación de gasa (tarlatana) para reforzar estructuralmente el lomo y colocación de cabezadas decorativas artesanales en rojo y blanco.",
		image: img5
	},
	{
		number: "05",
		title: "Encuadernación finalizada",
		description: "El libro de Niko Tesla completamente terminado y encuadernado en tapa dura con tela de color rojo vivo, listo para ser entregado.",
		image: img4
	}
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={favicon.src} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Encuadernación - Niko Tesla</title>
		<meta name="description" content="El proceso de encuadernación artesanal de Niko Tesla y el Ingenio de Silicio" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;400;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="grid-overlay" id="grid"></div>
		<div class="glow-container">
			<div class="glow-orb" id="orb1"></div>
			<div class="glow-orb-secondary" id="orb2"></div>
		</div>

		<main class="container">
			<header class="header">
				<a href="/" class="btn-back">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<line x1="19" y1="12" x2="5" y2="12"></line>
						<polyline points="12 19 5 12 12 5"></polyline>
					</svg>
					Volver
				</a>
				<div class="logo-wrapper">
					<a href="/"><img src={logo.src} alt="Niko Tesla Logo" class="logo" /></a>
				</div>
			</header>

			<section class="content-section">
				<div class="text-group">
					<h1 class="page-title">
						<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="title-icon"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6 6h10M6 10h10M6 14h10"/></svg>
						Encuadernación
					</h1>
					<p class="subtitle">Este es el proceso de encuadernación de <strong>Niko Tesla y el Ingenio de Silicio</strong>. Cada ejemplar se elabora de forma completamente manual, desde el plegado de hojas hasta la encuadernación final. Debido a las manos de cuto del autor, no debes esperar un resultado profesional.</p>
				</div>

				<div class="gallery-grid">
					{steps.map((step) => (
						<article class="gallery-card">
							<div
								class="card-image-wrapper"
								data-title={step.title}
								data-desc={step.description}
							>
								<span class="card-badge">{step.number}</span>
								<img src={step.image.src} alt={step.title} class="card-image" loading="lazy" />
							</div>
							<div class="card-body">
								<h2 class="card-title">{step.title}</h2>
								<p class="card-description">{step.description}</p>
							</div>
						</article>
					))}
				</div>
			</section>
		</main>

		<!-- Lightbox Modal -->
		<div class="lightbox" id="lightbox">
			<button class="lightbox-close" id="lightbox-close" aria-label="Cerrar">&times;</button>
			<div class="lightbox-content-wrapper">
				<img class="lightbox-img" id="lightbox-img" src="" alt="Vista ampliada" />
				<div class="lightbox-caption" id="lightbox-caption"></div>
			</div>
		</div>

		<script>
			const lightbox = document.getElementById("lightbox");
			const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
			const lightboxCaption = document.getElementById("lightbox-caption");
			const closeBtn = document.getElementById("lightbox-close");
			const imageWrappers = document.querySelectorAll(".card-image-wrapper");

			imageWrappers.forEach((wrapper) => {
				wrapper.addEventListener("click", () => {
					const img = wrapper.querySelector(".card-image") as HTMLImageElement;
					const title = wrapper.getAttribute("data-title");
					const desc = wrapper.getAttribute("data-desc");

					if (img && lightbox && lightboxImg && lightboxCaption) {
						lightboxImg.src = img.src;
						lightboxCaption.innerHTML = `<strong class="lightbox-caption-title">${title}</strong><span class="lightbox-caption-desc">${desc}</span>`;
						lightbox.classList.add("active");
						document.body.style.overflow = "hidden";
					}
				});
			});

			const closeLightbox = () => {
				if (lightbox) {
					lightbox.classList.remove("active");
					document.body.style.overflow = "";
				}
			};

			closeBtn?.addEventListener("click", closeLightbox);
			lightbox?.addEventListener("click", (e) => {
				if (e.target === lightbox) {
					closeLightbox();
				}
			});

			document.addEventListener("keydown", (e) => {
				if (e.key === "Escape") {
					closeLightbox();
				}
			});
		</script>
	</body>
</html>
